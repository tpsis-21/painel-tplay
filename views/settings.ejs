<%- include('layout_header', { title: 'Configurações Gerais' }) %>

<%
    const u = (settings && settings.universalTutorials) ? settings.universalTutorials : {};
    const legacyDownloader = u.videoDownloaderUrl || '';
    const androidTvValue = u.videoAndroidTvDownloaderUrl || legacyDownloader;
    const firestickValue = u.videoFirestickDownloaderUrl || legacyDownloader;
    const ntdownValue = u.videoNtDownUrl || '';
    const browserValue = u.videoBrowserDownloadUrl || '';
    const base = (typeof baseUrl !== 'undefined' && baseUrl) ? String(baseUrl) : '';
    function toAbsoluteUrl(url) {
        if (!url) return '';
        const s = String(url);
        if (s.startsWith('/')) return base.replace(/\/$/, '') + s;
        return s;
    }
%>

<div class="space-y-8">
    <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
        <div>
            <h1 class="text-3xl font-bold tracking-tight">Configurações Gerais</h1>
            <p class="text-muted-foreground text-sm">Defina vídeos tutoriais universais usados em todos os apps, com opção de sobrescrever por app quando necessário.</p>
        </div>
    </div>

    <form action="/painel/config" method="POST" enctype="multipart/form-data" class="space-y-6">
        <div class="rounded-lg border bg-card text-card-foreground shadow-sm">
            <div class="p-6 border-b">
                <h2 class="font-semibold tracking-tight">Vídeos Tutoriais Universais</h2>
                <p class="text-sm text-muted-foreground mt-1">Defina o link (URL) ou envie um arquivo de vídeo. Se enviar arquivo, o link será gerado automaticamente e você poderá copiá-lo.</p>
            </div>
            <div class="p-6 space-y-6">
                <div class="grid gap-6 md:grid-cols-2">
                    <div class="space-y-3">
                        <div>
                            <label class="text-sm font-medium">Vídeo tutorial Downloader (Android TV / Mi Stick)</label>
                            <p class="text-xs text-muted-foreground mt-1">Usado no bloco de instalação do Android TV.</p>
                        </div>
                        <div class="flex gap-2">
                            <input id="universal-androidtv-url" type="url" name="universalVideoAndroidTvDownloaderUrl" class="flex h-9 w-full rounded-md border border-input bg-background px-3 py-1 text-sm shadow-sm transition-colors placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring" value="<%= androidTvValue %>" placeholder="https://...">
                            <button type="button" onclick="window.copyUniversalLink('universal-androidtv-url')" class="inline-flex items-center justify-center rounded-md text-sm font-medium border border-input bg-background hover:bg-accent h-9 px-3">
                                <i class="fas fa-copy"></i>
                            </button>
                        </div>
                        <% if (androidTvValue) { %>
                            <p class="text-[11px] text-muted-foreground break-all">
                                Link atual: <a href="<%= toAbsoluteUrl(androidTvValue) %>" target="_blank" rel="noopener noreferrer" class="underline text-primary"><%= toAbsoluteUrl(androidTvValue) %></a>
                            </p>
                        <% } %>
                        <div>
                            <label class="text-xs font-medium text-muted-foreground">Ou enviar arquivo</label>
                            <input type="file" name="universal_androidtv_video_file" class="mt-1 block w-full text-sm text-muted-foreground file:mr-4 file:rounded-md file:border file:border-input file:bg-background file:px-3 file:py-2 file:text-sm file:font-medium hover:file:bg-accent file:cursor-pointer" accept="video/*">
                        </div>
                    </div>

                    <div class="space-y-3">
                        <div>
                            <label class="text-sm font-medium">Vídeo tutorial Downloader (Fire Stick)</label>
                            <p class="text-xs text-muted-foreground mt-1">Usado no bloco de instalação do Fire Stick.</p>
                        </div>
                        <div class="flex gap-2">
                            <input id="universal-firestick-url" type="url" name="universalVideoFirestickDownloaderUrl" class="flex h-9 w-full rounded-md border border-input bg-background px-3 py-1 text-sm shadow-sm transition-colors placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring" value="<%= firestickValue %>" placeholder="https://...">
                            <button type="button" onclick="window.copyUniversalLink('universal-firestick-url')" class="inline-flex items-center justify-center rounded-md text-sm font-medium border border-input bg-background hover:bg-accent h-9 px-3">
                                <i class="fas fa-copy"></i>
                            </button>
                        </div>
                        <% if (firestickValue) { %>
                            <p class="text-[11px] text-muted-foreground break-all">
                                Link atual: <a href="<%= toAbsoluteUrl(firestickValue) %>" target="_blank" rel="noopener noreferrer" class="underline text-primary"><%= toAbsoluteUrl(firestickValue) %></a>
                            </p>
                        <% } %>
                        <div>
                            <label class="text-xs font-medium text-muted-foreground">Ou enviar arquivo</label>
                            <input type="file" name="universal_firestick_video_file" class="mt-1 block w-full text-sm text-muted-foreground file:mr-4 file:rounded-md file:border file:border-input file:bg-background file:px-3 file:py-2 file:text-sm file:font-medium hover:file:bg-accent file:cursor-pointer" accept="video/*">
                        </div>
                    </div>
                </div>

                <div class="grid gap-6 md:grid-cols-2">
                    <div class="space-y-3">
                        <div>
                            <label class="text-sm font-medium">Vídeo tutorial NTDown (TV Box / Receptores / Projetores)</label>
                            <p class="text-xs text-muted-foreground mt-1">Mostra como usar o código NTDown para baixar e instalar o app.</p>
                        </div>
                        <div class="flex gap-2">
                            <input id="universal-ntdown-url" type="url" name="universalVideoNtDownUrl" class="flex h-9 w-full rounded-md border border-input bg-background px-3 py-1 text-sm shadow-sm transition-colors placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring" value="<%= ntdownValue %>" placeholder="https://...">
                            <button type="button" onclick="window.copyUniversalLink('universal-ntdown-url')" class="inline-flex items-center justify-center rounded-md text-sm font-medium border border-input bg-background hover:bg-accent h-9 px-3">
                                <i class="fas fa-copy"></i>
                            </button>
                        </div>
                        <% if (ntdownValue) { %>
                            <p class="text-[11px] text-muted-foreground break-all">
                                Link atual: <a href="<%= toAbsoluteUrl(ntdownValue) %>" target="_blank" rel="noopener noreferrer" class="underline text-primary"><%= toAbsoluteUrl(ntdownValue) %></a>
                            </p>
                        <% } %>
                        <div>
                            <label class="text-xs font-medium text-muted-foreground">Ou enviar arquivo</label>
                            <input type="file" name="universal_ntdown_video_file" class="mt-1 block w-full text-sm text-muted-foreground file:mr-4 file:rounded-md file:border file:border-input file:bg-background file:px-3 file:py-2 file:text-sm file:font-medium hover:file:bg-accent file:cursor-pointer" accept="video/*">
                        </div>
                    </div>

                    <div class="space-y-3">
                        <div>
                            <label class="text-sm font-medium">Vídeo tutorial Download via Navegador</label>
                            <p class="text-xs text-muted-foreground mt-1">Explica o processo de copiar/colar o link no navegador para baixar o app.</p>
                        </div>
                        <div class="flex gap-2">
                            <input id="universal-browser-url" type="url" name="universalVideoBrowserDownloadUrl" class="flex h-9 w-full rounded-md border border-input bg-background px-3 py-1 text-sm shadow-sm transition-colors placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring" value="<%= browserValue %>" placeholder="https://...">
                            <button type="button" onclick="window.copyUniversalLink('universal-browser-url')" class="inline-flex items-center justify-center rounded-md text-sm font-medium border border-input bg-background hover:bg-accent h-9 px-3">
                                <i class="fas fa-copy"></i>
                            </button>
                        </div>
                        <% if (browserValue) { %>
                            <p class="text-[11px] text-muted-foreground break-all">
                                Link atual: <a href="<%= toAbsoluteUrl(browserValue) %>" target="_blank" rel="noopener noreferrer" class="underline text-primary"><%= toAbsoluteUrl(browserValue) %></a>
                            </p>
                        <% } %>
                        <div>
                            <label class="text-xs font-medium text-muted-foreground">Ou enviar arquivo</label>
                            <input type="file" name="universal_browser_video_file" class="mt-1 block w-full text-sm text-muted-foreground file:mr-4 file:rounded-md file:border file:border-input file:bg-background file:px-3 file:py-2 file:text-sm file:font-medium hover:file:bg-accent file:cursor-pointer" accept="video/*">
                        </div>
                    </div>
                </div>
            </div>
            <div class="px-6 py-4 border-t flex justify-end">
                <button type="submit" class="inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:opacity-50 disabled:pointer-events-none ring-offset-background bg-primary text-primary-foreground hover:bg-primary/90 h-9 px-4">
                    <i class="fas fa-save mr-2"></i>
                    Salvar configurações
                </button>
            </div>
        </div>
    </form>
</div>

<script>
    window.copyUniversalLink = function(inputId) {
        const input = document.getElementById(inputId);
        if (!input) return;
        const raw = (input.value || '').trim();
        if (!raw) {
            showToast('Nenhum link para copiar.', 'error');
            return;
        }
        const base = '<%= base %>'.replace(/\/$/, '');
        const url = raw.startsWith('/') ? (base + raw) : raw;
        if (navigator.clipboard && window.isSecureContext) {
            navigator.clipboard.writeText(url).then(() => {
                showToast('Link copiado!');
            }).catch(() => {
                window.prompt('Copie o link:', url);
            });
        } else {
            window.prompt('Copie o link:', url);
        }
    }
</script>

<%- include('layout_footer') %>
