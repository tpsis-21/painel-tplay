        </main>
    </div>

    <div id="tplay-confirm-modal" class="fixed inset-0 z-[200] hidden items-center justify-center p-4 bg-black/60 backdrop-blur-sm" role="dialog" aria-modal="true" aria-labelledby="tplay-confirm-title" aria-describedby="tplay-confirm-desc">
        <div class="bg-card border border-border w-full max-w-lg rounded-xl shadow-2xl overflow-hidden">
            <div class="p-6 space-y-4">
                <div class="flex items-start justify-between gap-4">
                    <div class="min-w-0">
                        <h2 id="tplay-confirm-title" class="text-xl font-bold text-card-foreground">Confirmar ação</h2>
                        <p id="tplay-confirm-desc" class="text-sm text-muted-foreground mt-1"></p>
                    </div>
                    <button type="button" id="tplay-confirm-close" class="w-10 h-10 rounded-full bg-muted text-muted-foreground flex items-center justify-center hover:bg-accent hover:text-accent-foreground transition-colors" aria-label="Fechar">
                        <i class="fas fa-times"></i>
                    </button>
                </div>

                <div class="mt-6 flex flex-col-reverse sm:flex-row sm:justify-end gap-3">
                    <button type="button" id="tplay-confirm-cancel" class="inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:opacity-50 disabled:pointer-events-none ring-offset-background border border-input hover:bg-accent hover:text-accent-foreground h-10 px-4">
                        Cancelar
                    </button>
                    <button type="button" id="tplay-confirm-ok" class="inline-flex items-center justify-center rounded-md bg-destructive px-4 py-2 text-sm font-medium text-destructive-foreground shadow-sm transition-colors hover:bg-destructive/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2">
                        Confirmar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script>
        (function () {
            var modal = null;
            var titleEl = null;
            var descEl = null;
            var closeBtn = null;
            var cancelBtn = null;
            var okBtn = null;
            var onConfirmAction = null;
            var lastFocusEl = null;

            function closeConfirm() {
                if (!modal) return;
                modal.classList.add('hidden');
                modal.classList.remove('flex');
                document.body.style.overflow = '';
                onConfirmAction = null;
                if (lastFocusEl && typeof lastFocusEl.focus === 'function') lastFocusEl.focus();
                lastFocusEl = null;
            }

            function openConfirm(opts) {
                if (!modal) {
                    modal = document.getElementById('tplay-confirm-modal');
                    titleEl = document.getElementById('tplay-confirm-title');
                    descEl = document.getElementById('tplay-confirm-desc');
                    closeBtn = document.getElementById('tplay-confirm-close');
                    cancelBtn = document.getElementById('tplay-confirm-cancel');
                    okBtn = document.getElementById('tplay-confirm-ok');

                    if (!modal || !titleEl || !descEl || !cancelBtn || !okBtn) return;

                    if (closeBtn) closeBtn.addEventListener('click', closeConfirm);
                    cancelBtn.addEventListener('click', closeConfirm);
                    okBtn.addEventListener('click', function () {
                        var fn = onConfirmAction;
                        closeConfirm();
                        if (fn) fn();
                    });
                    modal.addEventListener('click', function (e) {
                        if (e.target === modal) closeConfirm();
                    });
                    document.addEventListener('keydown', function (e) {
                        if (e.key === 'Escape' && modal && !modal.classList.contains('hidden')) closeConfirm();
                    });
                }

                lastFocusEl = document.activeElement;
                titleEl.textContent = (opts && opts.title) ? String(opts.title) : 'Confirmar ação';
                descEl.textContent = (opts && opts.description) ? String(opts.description) : 'Tem certeza que deseja continuar?';
                okBtn.textContent = (opts && opts.confirmText) ? String(opts.confirmText) : 'Confirmar';
                onConfirmAction = (opts && typeof opts.onConfirm === 'function') ? opts.onConfirm : null;

                modal.classList.remove('hidden');
                modal.classList.add('flex');
                document.body.style.overflow = 'hidden';
                setTimeout(function () { cancelBtn.focus(); }, 0);
            }

            window.tplayConfirm = function (opts) {
                openConfirm(opts);
            };
        })();

        function toggleTheme() {
            const html = document.documentElement;
            html.classList.toggle('dark');
            localStorage.setItem('theme', html.classList.contains('dark') ? 'dark' : 'light');
        }

        (function() {
            if (localStorage.getItem('theme') === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                document.documentElement.classList.add('dark');
            } else {
                document.documentElement.classList.remove('dark');
            }
        })();
    </script>
</body>
</html>
