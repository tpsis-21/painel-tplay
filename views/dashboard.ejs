<%- include('layout_header', { title: 'Dashboard' }) %>

<div class="space-y-8">
    <div class="space-y-4">
        <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
            <div>
                <h1 class="text-3xl font-bold tracking-tight">Dashboard</h1>
                <p class="text-muted-foreground">Gerencie seus aplicativos cadastrados e configurações de página.</p>
            </div>
                    <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
                <div class="flex items-center gap-2">
                    <input
                        id="app-search"
                        type="search"
                        placeholder="Buscar por nome ou slug..."
                        class="flex h-9 w-full rounded-md border border-input bg-background px-3 py-1 text-sm shadow-sm placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring"
                    />
                    <select
                        id="app-visibility-filter"
                        class="flex h-9 w-36 rounded-md border border-input bg-background px-3 py-1 text-sm shadow-sm focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring"
                    >
                        <option value="all">Todos</option>
                        <option value="public">Públicos</option>
                        <option value="private">Privados</option>
                    </select>
                </div>
                <a href="/new" class="inline-flex items-center justify-center rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground shadow-sm transition-colors hover:bg-primary/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2">
                    <i class="fas fa-plus mr-2"></i>
                    Novo Aplicativo
                </a>
            </div>
        </div>
    </div>
    
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3" id="apps-grid">
        <% if (apps && apps.length > 0) { %>
            <% apps.forEach(app => { %>
                <div class="rounded-xl border bg-card text-card-foreground shadow hover:shadow-lg transition-shadow duration-200 app-card"
                     data-name="<%= app.name.toLowerCase() %>"
                     data-slug="<%= app.slug.toLowerCase() %>"
                     data-visibility="<%= app.visibleOnHome ? 'public' : 'private' %>">
                    <div class="p-6">
                        <div class="flex items-start justify-between">
                            <div class="flex items-center space-x-4">
                                <div class="flex h-16 w-16 items-center justify-center rounded-lg border bg-white p-2">
                                    <img src="<%= app.logo %>" alt="Logo <%= app.name %>" class="max-h-full max-w-full object-contain">
                                </div>
                                <div>
                                    <h3 class="font-semibold text-lg leading-none tracking-tight"><%= app.name %></h3>
                                    <p class="text-sm text-muted-foreground mt-1">/<%= app.slug %></p>
                                </div>
                            </div>
                            <div class="flex flex-col items-end space-y-2">
                                <% if (app.visibleOnHome) { %>
                                    <span class="inline-flex items-center rounded-full border border-transparent bg-green-100 px-2.5 py-0.5 text-xs font-semibold text-green-800 dark:bg-green-900/30 dark:text-green-400">Público</span>
                                <% } else { %>
                                    <span class="inline-flex items-center rounded-full border border-transparent bg-yellow-100 px-2.5 py-0.5 text-xs font-semibold text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-400">Privado</span>
                                <% } %>
                            </div>
                        </div>
                    </div>
                    <div class="flex items-center p-6 pt-0 space-x-2">
                        <button onclick="window.open('/<%= app.slug %>', '_blank')" class="inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:opacity-50 disabled:pointer-events-none ring-offset-background border border-input hover:bg-accent hover:text-accent-foreground h-9 px-3">
                            <i class="fas fa-external-link-alt mr-2"></i>
                            Visualizar
                        </button>
                        <button type="button" onclick="copiarLinkApp('<%= baseUrl %>/<%= app.slug %>')" class="inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:opacity-50 disabled:pointer-events-none ring-offset-background border border-input hover:bg-accent hover:text-accent-foreground h-9 px-3">
                            <i class="fas fa-link mr-2"></i>
                            Copiar link
                        </button>
                        <button onclick="window.location.href='/edit/<%= app.slug %>'" class="inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:opacity-50 disabled:pointer-events-none ring-offset-background bg-secondary text-secondary-foreground hover:bg-secondary/80 h-9 px-3">
                            <i class="fas fa-pencil-alt mr-2"></i>
                            Editar
                        </button>
                        <button type="button" data-slug="<%= app.slug %>" data-name="<%= app.name %>" onclick="abrirModalExclusao(this.dataset.slug, this.dataset.name)" class="inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:opacity-50 disabled:pointer-events-none ring-offset-background border border-input hover:bg-destructive hover:text-destructive-foreground h-9 px-3">
                            <i class="fas fa-trash mr-2"></i>
                            Excluir
                        </button>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div class="col-span-full">
                <div class="rounded-lg border border-dashed border-border p-8 text-center">
                    <i class="fas fa-inbox text-4xl text-muted-foreground mb-4"></i>
                    <h3 class="text-lg font-semibold mb-2">Nenhum aplicativo cadastrado</h3>
                    <p class="text-muted-foreground mb-4">Comece criando seu primeiro aplicativo</p>
                    <button onclick="window.location.href='/new'" class="inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:opacity-50 disabled:pointer-events-none ring-offset-background bg-primary text-primary-foreground hover:bg-primary/90 h-10 px-4 py-2">
                        <i class="fas fa-plus mr-2"></i>
                        Criar Primeiro App
                    </button>
                </div>
            </div>
        <% } %>
    </div>
    </div>
</div>

<div id="delete-modal" class="fixed inset-0 z-[120] hidden items-center justify-center p-4 bg-black/60 backdrop-blur-sm" role="dialog" aria-modal="true" aria-labelledby="delete-title" aria-describedby="delete-desc">
    <div class="bg-card border border-border w-full max-w-lg rounded-xl shadow-2xl overflow-hidden">
        <div class="p-6 space-y-4">
            <div class="flex items-start justify-between gap-4">
                <div class="min-w-0">
                    <h2 id="delete-title" class="text-xl font-bold text-card-foreground">Confirmar exclusão</h2>
                    <p id="delete-desc" class="text-sm text-muted-foreground mt-1">
                        Essa ação remove o app do painel e do site público.
                    </p>
                </div>
                <button type="button" id="delete-close" class="w-10 h-10 rounded-full bg-muted text-muted-foreground flex items-center justify-center hover:bg-accent hover:text-accent-foreground transition-colors" aria-label="Fechar">
                    <i class="fas fa-times"></i>
                </button>
            </div>

            <div class="rounded-lg border border-border bg-muted/30 p-4">
                <p class="text-sm text-card-foreground">
                    App: <span id="delete-app-name" class="font-semibold"></span>
                </p>
                <p class="text-xs text-muted-foreground mt-1">
                    Para confirmar, digite o slug: <span id="delete-app-slug" class="font-mono"></span>
                </p>
            </div>

            <form id="delete-form" method="POST" action="">
                <input type="hidden" name="confirmed" value="true" />
                <div class="space-y-3">
                    <div class="space-y-2">
                        <label for="delete-confirm-slug" class="text-sm font-medium text-card-foreground">Digite o slug para confirmar</label>
                        <input id="delete-confirm-slug" name="confirmSlug" type="text" autocomplete="off" spellcheck="false"
                            class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm shadow-sm placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring"
                            placeholder="ex: access-play"
                        />
                        <p id="delete-hint" class="text-xs text-muted-foreground">O botão de excluir só é liberado quando o slug estiver correto.</p>
                    </div>

                    <div class="flex items-start gap-3">
                        <input id="delete-check" type="checkbox" class="mt-1 h-4 w-4 rounded border-input bg-background text-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 ring-offset-background" />
                        <label for="delete-check" class="text-sm text-card-foreground">
                            Entendo que essa ação é permanente e não pode ser desfeita.
                        </label>
                    </div>
                </div>

                <div class="mt-6 flex flex-col-reverse sm:flex-row sm:justify-end gap-3">
                    <button type="button" id="delete-cancel" class="inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:opacity-50 disabled:pointer-events-none ring-offset-background border border-input hover:bg-accent hover:text-accent-foreground h-10 px-4">
                        Cancelar
                    </button>
                    <button type="submit" id="delete-submit" disabled class="inline-flex items-center justify-center rounded-md bg-destructive px-4 py-2 text-sm font-medium text-destructive-foreground shadow-sm transition-colors hover:bg-destructive/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:opacity-50 disabled:pointer-events-none">
                        Excluir app
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        var searchInput = document.getElementById('app-search');
        var visibilitySelect = document.getElementById('app-visibility-filter');
        var cards = Array.prototype.slice.call(document.querySelectorAll('.app-card'));

        function applyFilters() {
            var search = (searchInput.value || '').toLowerCase().trim();
            var visibility = visibilitySelect.value;

            cards.forEach(function (card) {
                var name = card.getAttribute('data-name') || '';
                var slug = card.getAttribute('data-slug') || '';
                var status = card.getAttribute('data-visibility') || 'public';

                var matchesSearch = !search || name.indexOf(search) !== -1 || slug.indexOf(search) !== -1;
                var matchesVisibility = visibility === 'all' || status === visibility;

                card.style.display = (matchesSearch && matchesVisibility) ? '' : 'none';
            });
        }

        if (searchInput && visibilitySelect && cards.length > 0) {
            searchInput.addEventListener('input', applyFilters);
            visibilitySelect.addEventListener('change', applyFilters);
        }
    });

    function copiarLinkApp(url) {
        if (navigator.clipboard && window.isSecureContext) {
            navigator.clipboard.writeText(url)
                .then(function () {
                    alert('Link copiado. Agora você pode colar e compartilhar o endereço do app.');
                })
                .catch(function () {
                    window.prompt('Copie o link do aplicativo:', url);
                });
        } else {
            window.prompt('Copie o link do aplicativo:', url);
        }
    }

    var deleteModal = document.getElementById('delete-modal');
    var deleteForm = document.getElementById('delete-form');
    var deleteAppName = document.getElementById('delete-app-name');
    var deleteAppSlug = document.getElementById('delete-app-slug');
    var deleteConfirmSlug = document.getElementById('delete-confirm-slug');
    var deleteCheck = document.getElementById('delete-check');
    var deleteSubmit = document.getElementById('delete-submit');
    var deleteClose = document.getElementById('delete-close');
    var deleteCancel = document.getElementById('delete-cancel');
    var lastDeleteTrigger = null;
    var deleteExpectedSlug = '';

    function atualizarDeleteSubmit() {
        var slugOk = (deleteConfirmSlug.value || '').trim() === deleteExpectedSlug;
        var checked = !!deleteCheck.checked;
        deleteSubmit.disabled = !(slugOk && checked);
    }

    function fecharModalExclusao() {
        if (!deleteModal) return;
        deleteModal.classList.add('hidden');
        deleteModal.classList.remove('flex');
        document.body.style.overflow = '';
        deleteConfirmSlug.value = '';
        deleteCheck.checked = false;
        deleteExpectedSlug = '';
        atualizarDeleteSubmit();
        if (lastDeleteTrigger && typeof lastDeleteTrigger.focus === 'function') {
            lastDeleteTrigger.focus();
        }
        lastDeleteTrigger = null;
    }

    function abrirModalExclusao(slug, name) {
        lastDeleteTrigger = document.activeElement;
        deleteExpectedSlug = String(slug || '');
        deleteAppName.textContent = String(name || '');
        deleteAppSlug.textContent = deleteExpectedSlug;
        deleteForm.action = '/delete/' + encodeURIComponent(deleteExpectedSlug);
        deleteModal.classList.remove('hidden');
        deleteModal.classList.add('flex');
        document.body.style.overflow = 'hidden';
        atualizarDeleteSubmit();
        setTimeout(function () {
            deleteConfirmSlug.focus();
        }, 0);
    }

    if (deleteConfirmSlug) deleteConfirmSlug.addEventListener('input', atualizarDeleteSubmit);
    if (deleteCheck) deleteCheck.addEventListener('change', atualizarDeleteSubmit);
    if (deleteClose) deleteClose.addEventListener('click', fecharModalExclusao);
    if (deleteCancel) deleteCancel.addEventListener('click', fecharModalExclusao);
    if (deleteModal) {
        deleteModal.addEventListener('click', function (e) {
            if (e.target === deleteModal) fecharModalExclusao();
        });
    }
    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && deleteModal && !deleteModal.classList.contains('hidden')) {
            fecharModalExclusao();
        }
    });
</script>

<%- include('layout_footer') %>
